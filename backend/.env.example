# Copy to backend/.env and fill in once the LocalStack KB is created
# (see localstack-init/03-create-bedrock-knowledge-base.sh output).
# Leave BEDROCK_KNOWLEDGE_BASE_ID empty to run on local fallback answers only.

AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-haiku-20240307-v1:0
