# -----------------------------------------------------------------------
# .env.local — Local development environment variables for AWS-IQ
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and should NEVER be committed.
# -----------------------------------------------------------------------

# LocalStack Pro auth token
# Get yours at: https://app.localstack.cloud/account/auth-token
# Leave empty to use the community edition (Bedrock mock will be unavailable)
LOCALSTACK_AUTH_TOKEN=

# AWS SDK configuration for local development
# These dummy credentials are required by the AWS SDK even for LocalStack
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Lambda executor: "docker" for full isolation, "local" for faster cold starts
LAMBDA_EXECUTOR=docker

# Set to 1 for verbose LocalStack debug output
DEBUG=0
